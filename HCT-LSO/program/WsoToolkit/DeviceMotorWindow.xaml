                    <ComboBox x:Name="cmbAntLensFilter" Style="{StaticResource ComboBoxStyle}" Width="72" Margin="4,0,12,0"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                    <Button x:Name="btnAntLensSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="8,0,24,0" Click="BtnAntLensSetAs_Click"/>
                    <Button x:Name="btnAntLensOut" Content="Out" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnAntLensOut_Click"/>
                    <Button x:Name="btnAntLensIn" Content="In" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnAntLensIn_Click"/>
                </StackPanel>
                <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.RowSpan="3" Margin="0,0,0,10"/>
            </Grid>
            <Grid Grid.Row="0" Grid.Column="4">
