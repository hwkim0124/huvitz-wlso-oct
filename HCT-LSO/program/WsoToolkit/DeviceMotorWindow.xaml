                    <Slider x:Name="sliderOctRefer" Style="{StaticResource SliderStyle}" Thumb.DragStarted="SliderOctRefer_DragStarted" ValueChanged="SliderOctRefer_ValueChanged" Thumb.DragCompleted="SliderOctRefer_DragCompleted" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
