                    <ComboBox x:Name="cmbOctMirrorFilter" Style="{StaticResource ComboBoxStyle}" Width="72" Margin="4,0,0,0" SelectionChanged="CmbOctMirrorFilter_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                    <Button x:Name="btnOctMirrorSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="8,0,24,0" Click="BtnOctMirrorSetAs_Click"/>
                    <Button x:Name="btnOctMirrorOut" Content="Out" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnOctMirrorOut_Click"/>
                    <Button x:Name="btnOctMirrorIn" Content="In" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnOctMirrorIn_Click"/>
                </StackPanel>
                <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Margin="0,0,0,10" Grid.RowSpan="3"/>
