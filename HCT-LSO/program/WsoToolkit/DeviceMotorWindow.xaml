                    <TextBox x:Name="editLsoFocusValue" Style="{StaticResource TextBoxS1Style}" Margin="4,0,8,0" KeyDown="EditLsoFocusValue_KeyDown"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                    <Button x:Name="btnLsoFocusOrigin" Content="0D" Style="{StaticResource ButtonS1Style}" Margin="8,0,4,0" Click="BtnLsoFocusOrigin_Click"/>
                    <Button x:Name="btnLsoFocusSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="0,0,16,0" Click="BtnLsoFocusSetAs_Click"/>
                    <Button x:Name="btnLsoFocusBwd" Content="1D-" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnLsoFocusBwd_Click"/>
                    <Button x:Name="btnLsoFocusFwd" Content="1D+" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnLsoFocusFwd_Click"/>
                </StackPanel>
