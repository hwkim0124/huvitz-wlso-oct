                    <Button x:Name="btnYstageSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="0,0,16,0" Click="BtnYstageSetAs_Click"/>
                    <Button x:Name="btnYstageBwd" Content="Step+" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnYstageBwd_Click"/>
                    <Button x:Name="btnYstageFwd" Content="Step-" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnYstageFwd_Click"/>
                </StackPanel>
                <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Margin="0,0,0,10" Grid.RowSpan="3"/>
            </Grid>
            <Grid Grid.Row="4" Grid.Column="4">
