<Window x:Class="WsoToolkit.XadcMonitorWindow"
        Style="{StaticResource WindowStyle}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WsoToolkit"
        mc:Ignorable="d"
        Title="Zync xADC Monitor" Height="240" Width="400" Initialized="Window_Initialized" Loaded="Window_Loaded" Closed="Window_Closed" ResizeMode="NoResize">
    <Grid Margin="12,12,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label x:Name="label_z1" Content="Zync xADC" Style="{StaticResource HeaderStyle}" Grid.ColumnSpan="4"/>
            <Label x:Name="label_z4" Content="Cpu Temp." Style="{StaticResource LabelStyle}" Grid.Row="3" Grid.Column="0"/>
            <Label x:Name="label_z5" Content="External PD" Style="{StaticResource LabelStyle}" Grid.Row="3" Grid.Column="2"/>
            <Label x:Name="label_z6" Content="Hall Sensor-1" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="0"/>
            <Label x:Name="label_z7" Content="Hall Sensor-2" Style="{StaticResource LabelStyle}" Grid.Row="5" Grid.Column="0"/>
            <Label x:Name="label_z8" Content="Odos" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="2"/>
            <TextBox x:Name="editZyncCpuTemp" Style="{StaticResource TextBoxStyle}" Grid.Row="3" Grid.Column="1" IsReadOnly="True"/>
            <TextBox x:Name="editZyncExternPd" Style="{StaticResource TextBoxStyle}" Grid.Row="3" Grid.Column="3" IsReadOnly="True"/>
            <TextBox x:Name="editZyncHallSensor1" Style="{StaticResource TextBoxStyle}" Grid.Row="4" Grid.Column="1" IsReadOnly="True"/>
            <TextBox x:Name="editZyncHallSensor2" Style="{StaticResource TextBoxStyle}" Grid.Row="5" Grid.Column="1" IsReadOnly="True"/>
            <TextBox x:Name="editZyncOdos" Style="{StaticResource TextBoxStyle}" Grid.Row="4" Grid.Column="3" IsReadOnly="True"/>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.ColumnSpan="4" Margin="0,0,0,0" Grid.RowSpan="7"/>
        </Grid>
    </Grid>
</Window>
