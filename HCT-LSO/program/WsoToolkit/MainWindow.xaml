<Window x:Class="WsoToolkit.MainWindow"
        Style="{StaticResource WindowStyle}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WsoToolkit"
        mc:Ignorable="d"
        Title="Wide LSO-OCT Toolkit SW" Height="900" Width="1032" ResizeMode="NoResize" Loaded="WindowMain_Loaded" Closed="WindowMain_Closed" Closing="WindowMain_Closing" WindowStartupLocation="CenterScreen" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">
                <Button x:Name="StartupButton" Content="Startup WSO System" Style="{StaticResource ButtonStyle}" Width="200" Click="StartupButton_Click"/>
                <Button x:Name="ReleaseButton" Content="Release WSO System" Style="{StaticResource ButtonStyle}" Width="200" Margin="0,12,0,0" Click="ReleaseButton_Click" IsEnabled="False"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="2">
                <Button x:Name="btnLsoScanMode" Content="LSO Scan Mode" Width="200" Margin="0,0,0,0" Style="{StaticResource ButtonStyle}" Click="BtnSloScanMode_Click"/>
                <Button x:Name="btnOctScanMode" Content="OCT Scan Mode" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="btnOctScanMode_Click"/>
                <Button x:Name="btnOctAngioMode" Content="OCT Angio Mode" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="btnOctAngioMode_Click"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="3">
                <Button x:Name="btnLsoScanTest" Content="LSO Scanner Test" Width="200" Style="{StaticResource ButtonStyle}" Click="BtnSloScanTest_Click"/>
                <Button x:Name="btnOctSignalTest" Content="OCT Signal Test" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="btnOctSignalTest_Click"/>
                <Button x:Name="btnOctSpectroCalib" Content="OCT Spectrometer Calib." Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="BtnOctSpectroCalib_Click"/>
                <Button x:Name="btnDeviceMotorTest" Content="Device Motor Test" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="BtnDeviceMotorTest_Click"/>
                <Button x:Name="btnIrCameraTest" Content="IR Camera Test" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="BtnIrCameraTest_Click"/>
                <Button x:Name="btnLongRunTest" Content="Long Run Test" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="BtnLongRunTest_Click"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="4">
                <Button x:Name="btnOctSldControl" Content="OCT SLD Control" Width="200" Margin="0,0,0,0" Style="{StaticResource ButtonStyle}" Click="BtnOctSldControl_Click"/>
                <Button x:Name="btnXadcMonitor" Content="xADC Monitor" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="BtnXadcMonitor_Click"/>
                <Button x:Name="ConfigreButton" Content="System Configuration" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="ConfigreButton_Click" />
                <Button x:Name="CalibrationButton" Content="System Calibration" Width="200" Margin="0,12,0,0" Style="{StaticResource ButtonStyle}" Click="CalibrationButton_Click" />

            </StackPanel>
            <Border Style="{StaticResource BorderStyle}" Grid.Column="1" Grid.ColumnSpan="6" Grid.RowSpan="5"/>
        </Grid>

        <ListBox x:Name="LogMsgListBox" Grid.Row="2" Margin="0,12,0,0" Height="480" ScrollViewer.VerticalScrollBarVisibility="Visible">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Message}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
