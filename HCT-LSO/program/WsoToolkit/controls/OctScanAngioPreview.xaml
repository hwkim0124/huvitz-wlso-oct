<UserControl x:Class="WsoToolkit.controls.OctScanAngioPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WsoToolkit.controls"
             mc:Ignorable="d">
    <Grid Background="White">
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="320"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <Grid x:Name="imageBorder" Grid.Row="0" Grid.Column="0" Background="LightGray">
                <Image x:Name="imageViewport" Style="{StaticResource ImageStyle}" Stretch="Uniform"/>
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="8,4,8,4">
                <Label x:Name="lblStatus" Content="Oct Angiography" Height="Auto" Style="{StaticResource LabelStyle}"/>
            </StackPanel>
        </Grid>
        <Border Style="{StaticResource BorderStyle}"/>
    </Grid>
</UserControl>
