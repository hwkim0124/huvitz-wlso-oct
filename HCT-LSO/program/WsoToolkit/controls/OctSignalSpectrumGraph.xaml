<UserControl x:Class="WsoToolkit.controls.OctSignalSpectrumGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WsoToolkit.controls"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d" 
             Width="512" Height="360">
    <Grid Background="White">
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="320"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <oxy:PlotView x:Name="plotView"/>
            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="8, 4, 8, 4">
                <Label x:Name="lblStatus" Content="OCT Signal Spectrum" Style="{StaticResource LabelStyle}" Height="Auto"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
