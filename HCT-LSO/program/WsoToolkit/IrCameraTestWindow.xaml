<Window x:Class="WsoToolkit.IrCameraTestWindow"
        Style="{StaticResource WindowStyle}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WsoToolkit"
        xmlns:controls="clr-namespace:WsoToolkit.controls"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
       Title="Ir Camera Test" Height="Auto" Width="Auto" ResizeMode="NoResize" Initialized="Window_Initialized" Loaded="Window_Loaded" Closed="Window_Closed" Closing="Window_Closing">
    <Grid Margin="4,4,4,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
            <controls:CorneaCameraPreview x:Name="corneaPreview1" Width="640" Height="512"/>
            <controls:CorneaCameraPreview x:Name="corneaPreview2" Width="640" Height="512"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Vertical">
            <controls:CorneaCameraPreview x:Name="corneaPreview3" Width="640" Height="512"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,16,0,4">
                <Button x:Name="btnStartCamera" Content="Start Camera" Style="{StaticResource ButtonStyle}" Margin="0" Click="BtnStartCamera_Click"/>
                <Button x:Name="btnClose" Content="Close" Style="{StaticResource ButtonStyle}" Margin="8,0,0,0" Click="BtnClose_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,4">
                <Button x:Name="btnShowFocusM" Content="FocusM..." Style="{StaticResource ButtonStyle}" Margin="0" Click="BtnShowFocusM_Click"/>
                <Button x:Name="btnShowStageM" Content="StageM..." Style="{StaticResource ButtonStyle}" Margin="8,0,0,0" Click="BtnShowStageM_Click"/>
                <Button x:Name="btnShowLights" Content="Lights..." Style="{StaticResource ButtonStyle}" Margin="8,0,0,0" Click="BtnShowLights_Click"/>
                <Button x:Name="btnShowConfig" Content="Config..." Style="{StaticResource ButtonStyle}" Margin="8,0,0,0" Click="BtnShowConfig_Click"/>
            </StackPanel>

            <Grid Margin="0,16,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>
                <Label x:Name="label301" Content="Cornea Ir Camera (Left)" Style="{StaticResource HeaderStyle}" Grid.Row="1" Grid.ColumnSpan="3"/>
                <Label x:Name="label302" Content="Analog Gain" Style="{StaticResource LabelStyle}" Grid.Row="2" Grid.Column="1"/>
                <TextBox x:Name="editCorneaAgain1" Style="{StaticResource TextBoxStyle}" Grid.Column="2" Grid.Row="2" KeyDown="EditCorneaAgain1_KeyDown"/>
                <Label x:Name="label303" Content="Digital Gain" Style="{StaticResource LabelStyle}" Grid.Row="2" Grid.Column="3"/>
                <TextBox x:Name="editCorneaDgain1" Style="{StaticResource TextBoxStyle}" Grid.Column="4" Grid.Row="2" KeyDown="EditCorneaDgain1_KeyDown"/>
                <CheckBox x:Name="checkAlignGuide1" Content="Align Guide" Style="{StaticResource CheckBoxStyle}" Grid.Row="2" Grid.Column="6" Click="checkAlignGuide1_Click"/>

                <Label x:Name="label401" Content="Cornea Ir Camera (Right)" Style="{StaticResource HeaderStyle}" Grid.Row="3" Grid.ColumnSpan="3"/>
                <Label x:Name="label402" Content="Analog Gain" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="1"/>
                <TextBox x:Name="editCorneaAgain2" Style="{StaticResource TextBoxStyle}" Grid.Column="2" Grid.Row="4" KeyDown="EditCorneaAgain2_KeyDown"/>
                <Label x:Name="label403" Content="Digital Gain" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="3"/>
                <TextBox x:Name="editCorneaDgain2" Style="{StaticResource TextBoxStyle}" Grid.Column="4" Grid.Row="4" KeyDown="EditCorneaDgain2_KeyDown"/>
                <CheckBox x:Name="checkAlignGuide2" Content="Align Guide" Style="{StaticResource CheckBoxStyle}" Grid.Row="4" Grid.Column="6" Click="checkAlignGuide2_Click"/>

                <Label x:Name="label501" Content="Cornea Ir Camera (Lower)" Style="{StaticResource HeaderStyle}" Grid.Row="5" Grid.ColumnSpan="3"/>
                <Label x:Name="label502" Content="Analog Gain" Style="{StaticResource LabelStyle}" Grid.Row="6" Grid.Column="1"/>
                <TextBox x:Name="editCorneaAgain3" Style="{StaticResource TextBoxStyle}" Grid.Column="2" Grid.Row="6" KeyDown="EditCorneaAgain3_KeyDown"/>
                <Label x:Name="label503" Content="Digital Gain" Style="{StaticResource LabelStyle}" Grid.Row="6" Grid.Column="3"/>
                <TextBox x:Name="editCorneaDgain3" Style="{StaticResource TextBoxStyle}" Grid.Column="4" Grid.Row="6" KeyDown="EditCorneaDgain3_KeyDown"/>
                <CheckBox x:Name="checkAlignGuide3" Content="Align Guide" Style="{StaticResource CheckBoxStyle}" Grid.Row="6" Grid.Column="6" Click="checkAlignGuide3_Click"/>

                <Border Style="{StaticResource BorderStyle}" Grid.ColumnSpan="7" Grid.RowSpan="8"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
