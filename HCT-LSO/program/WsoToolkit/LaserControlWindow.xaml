<Window x:Class="WsoToolkit.LaserControlWindow"
        Style="{StaticResource WindowStyle}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WsoToolkit"
        mc:Ignorable="d"
        Title="Source Leds Control" Height="336" Width="412" Initialized="Window_Initialized" Loaded="Window_Loaded" Closed="Window_Closed" ResizeMode="NoResize">
    <Grid  Margin="12,12,12,12">
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label x:Name="label_s1" Content="SLD" Style="{StaticResource HeaderStyle}" Grid.ColumnSpan="4"/>
            <Label x:Name="label_s2" Content="LD SN." Style="{StaticResource LabelStyle}" Grid.Row="2" Grid.Column="0"/>
            <TextBox x:Name="editSldSerialName"  Style="{StaticResource TextBoxStyle}" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Width="120"/>
            <Label x:Name="label_s3" Content="Profile" Style="{StaticResource LabelStyle}" Grid.Row="1" Grid.Column="0"/>
            <ComboBox x:Name="cmbSldProfile" Style="{StaticResource ComboBoxStyle}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Width="120" Margin="0,0,0,0"/>
            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" FlowDirection="RightToLeft">
                <Button x:Name="btnSldOff" Content="OFF" Style="{StaticResource ButtonS1Style}" Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" Click="BtnSldOff_Click"/>
                <Button x:Name="btnSldOn" Content="ON" Style="{StaticResource ButtonS1Style}" Grid.Row="1" Grid.Column="0" Margin="4,0,0,0" Click="BtnSldOn_Click"/>
            </StackPanel>
            <Label x:Name="label_s4" Content="High Code" Style="{StaticResource LabelStyle}" Grid.Row="3" Grid.Column="0"/>
            <Label x:Name="label_s5" Content="Low Code1" Style="{StaticResource LabelStyle}" Grid.Row="3" Grid.Column="2"/>
            <Label x:Name="label_s6" Content="Rsi Code" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="0"/>
            <Label x:Name="label_s7" Content="Low Code2" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="2"/>
            <Label x:Name="label_s10" Content="SLD Current" Style="{StaticResource LabelStyle}" Grid.Row="6" Grid.Column="0"/>
            <Label x:Name="label_s11" Content="IPD Current" Style="{StaticResource LabelStyle}" Grid.Row="7" Grid.Column="0"/>
            <Label x:Name="label_s12" Content="External PD" Style="{StaticResource LabelStyle}" Grid.Row="6" Grid.Column="2"/>
            <Label x:Name="label_s13" Content="Temperature" Style="{StaticResource LabelStyle}" Grid.Row="7" Grid.Column="2"/>
            <TextBox x:Name="editSldHighCode" Style="{StaticResource TextBoxStyle}" Grid.Row="3" Grid.Column="1" KeyDown="EditSldHighCode_KeyDown"/>
            <TextBox x:Name="editSldLowCode1" Style="{StaticResource TextBoxStyle}" Grid.Row="3" Grid.Column="3" KeyDown="EditSldLowCode1_KeyDown"/>
            <TextBox x:Name="editSldRsiCode" Style="{StaticResource TextBoxStyle}" Grid.Row="4" Grid.Column="1" KeyDown="EditSldRsiCode_KeyDown"/>
            <TextBox x:Name="editSldLowCode2" Style="{StaticResource TextBoxStyle}" Grid.Row="4" Grid.Column="3" KeyDown="EditSldLowCode2_KeyDown"/>
            <TextBox x:Name="editSldSldCurrent" Style="{StaticResource TextBoxStyle}" Grid.Row="6" Grid.Column="1" IsReadOnly="True"/>
            <TextBox x:Name="editSldIpdCurrent" Style="{StaticResource TextBoxStyle}" Grid.Row="7" Grid.Column="1" IsReadOnly="True"/>
            <TextBox x:Name="editSldExternPd" Style="{StaticResource TextBoxStyle}" Grid.Row="6" Grid.Column="3" IsReadOnly="True"/>
            <TextBox x:Name="editSldTemperature" Style="{StaticResource TextBoxStyle}" Grid.Row="7" Grid.Column="3" IsReadOnly="True"/>
            <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" FlowDirection="RightToLeft">
                <Button x:Name="btnSldSave" Content="Save" Style="{StaticResource ButtonS1Style}" Margin="16,0,0,0" Click="BtnSldSave_Click"/>
                <Button x:Name="btnSldApply" Content="Apply" Style="{StaticResource ButtonS1Style}" Margin="8,0,0,0" Click="BtnSldApply_Click"/>
                <Button x:Name="btnSldGet" Content="Get" Style="{StaticResource ButtonS1Style}" Margin="8,0,0,0" Click="BtnSldGet_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.ColumnSpan="4" Grid.RowSpan="11"/>
        </Grid>
    </Grid>
</Window>
