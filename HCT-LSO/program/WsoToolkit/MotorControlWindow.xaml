<Window x:Class="WsoToolkit.MotorControlWindow"
        Style="{StaticResource WindowStyle}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WsoToolkit"
        mc:Ignorable="d"
        Title="Motor Control" Height="Auto" Width="Auto" ResizeMode="NoResize" SizeToContent="WidthAndHeight" Loaded="Window_Loaded" Initialized="Window_Initialized" Closed="Window_Closed">
    <Grid Margin="12,12,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label" Content="OCT Focus" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderOctFocus" Style="{StaticResource SliderStyle}" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0" Thumb.DragStarted="SliderOctFocus_DragStarted" Thumb.DragCompleted="SliderOctFocus_DragCompleted" ValueChanged="SliderOctFocus_ValueChanged"/>
                <TextBox x:Name="editOctFocusPos"  Style="{StaticResource TextBoxS1Style}" Margin="8,0,0,0" KeyDown="EditOctFocusPos_KeyDown"/>
                <TextBox x:Name="editOctFocusValue" Style="{StaticResource TextBoxS1Style}" Margin="4,0,8,0" KeyDown="EditOctFocusValue_KeyDown"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnOctFocusOrigin" Content="0D" Style="{StaticResource ButtonS1Style}" Margin="8,0,4,0" Click="BtnOctFocusOrigin_Click"/>
                <Button x:Name="btnOctFocusSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="0,0,16,0" Click="BtnOctFocusSetAs_Click"/>
                <Button x:Name="btnOctFocusBwd" Content="1D-" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnOctFocusBwd_Click"/>
                <Button x:Name="btnOctFocusFwd" Content="1D+" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnOctFocusFwd_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.RowSpan="3" Margin="0,0,0,10"/>
        </Grid>
        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label2" Content="OCT Reference" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderOctRefer" Style="{StaticResource SliderStyle}" Thumb.DragStarted="SliderOctRefer_DragStarted" ValueChanged="SliderOctRefer_ValueChanged" Thumb.DragCompleted="SliderOctRefer_DragCompleted" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
                <TextBox x:Name="editOctReferPos" Style="{StaticResource TextBoxS1Style}" Margin="8,0,0,0" KeyDown="EditOctReferPos_KeyDown"/>
                <TextBox x:Name="editOctReferStep" Style="{StaticResource TextBoxS1Style}" Margin="4,0,8,0" KeyDown="editOctReferStep_KeyDown"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnOctReferOrigin" Content="Origin" Style="{StaticResource ButtonS1Style}" Margin="8,0,4,0" Click="BtnOctReferOrigin_Click"/>
                <Button x:Name="btnOctReferSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="0,0,16,0" Click="BtnOctReferSetAs_Click"/>
                <Button x:Name="btnOctReferBwd" Content="Step+" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnOctReferBwd_Click"/>
                <Button x:Name="btnOctReferFwd" Content="Step-" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnOctReferFwd_Click"/>
                <CheckBox x:Name="checkOctReferCornea" Content="Cornea" Style="{StaticResource CheckBoxStyle}" Margin="0,0,12,0" FlowDirection="LeftToRight" Click="checkOctReferAnterior_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.RowSpan="3" Margin="0,0,0,10"/>
        </Grid>
        <Grid Grid.Row="4" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label3" Content="OCT Polarization" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderOctPolar" Style="{StaticResource SliderStyle}" ValueChanged="sliderOctPolar_ValueChanged" Thumb.DragStarted="sliderOctPolar_DragStarted" Thumb.DragCompleted="SliderOctPolar_DragCompleted" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
                <TextBox x:Name="editOctPolarPos" Style="{StaticResource TextBoxS1Style}" Margin="8,0,0,0" KeyDown="EditOctPolarPos_KeyDown"/>
                <TextBox x:Name="editOctPolarValue" Style="{StaticResource TextBoxS1Style}" Margin="4,0,8,0" KeyDown="EditOctPolarValue_KeyDown"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnOctPolarOrigin" Content="Origin" Style="{StaticResource ButtonS1Style}" Margin="8,0,4,0" FlowDirection="LeftToRight" Click="BtnOctPolarOrigin_Click"/>
                <Button x:Name="btnOctPolarSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="0,0,16,0" Click="BtnOctPolarSetAs_Click"/>
                <Button x:Name="btnOctPolarBwd" Content="+15 deg" FlowDirection="LeftToRight" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnOctPolarBwd_Click"/>
                <Button x:Name="btnOctPolarFwd" Content="-15 deg" FlowDirection="LeftToRight" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnOctPolarFwd_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Margin="0,0,0,10" Grid.RowSpan="3"/>
        </Grid>
        <Grid Grid.Row="6" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label7" Content="Return Mirror" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderOctMirror" Style="{StaticResource SliderStyle}" ValueChanged="SliderOctMirror_ValueChanged" Thumb.DragStarted="SliderOctMirror_DragStarted" Thumb.DragCompleted="SliderOctMirror_DragCompleted" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
                <TextBox x:Name="editOctMirrorPos" Style="{StaticResource TextBoxS1Style}" Margin="8,0,0,0" KeyDown="EditOctMirrorPos_KeyDown"/>
                <ComboBox x:Name="cmbOctMirrorFilter" Style="{StaticResource ComboBoxStyle}" Width="72" Margin="4,0,0,0" SelectionChanged="CmbOctMirrorFilter_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnOctMirrorSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="8,0,24,0" Click="BtnOctMirrorSetAs_Click"/>
                <Button x:Name="btnOctMirrorOut" Content="Out" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnOctMirrorOut_Click"/>
                <Button x:Name="btnOctMirrorIn" Content="In" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnOctMirrorIn_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Margin="0,0,0,10" Grid.RowSpan="3"/>
        </Grid>
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label4" Content="LSO Focus" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderLsoFocus" Style="{StaticResource SliderStyle}" ValueChanged="SliderLsoFocus_ValueChanged" Thumb.DragStarted="SliderLsoFocus_DragStarted" Thumb.DragCompleted="SliderLsoFocus_DragCompleted" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
                <TextBox x:Name="editLsoFocusPos" Style="{StaticResource TextBoxS1Style}" Margin="8,0,0,0" KeyDown="EditLsoFocusPos_KeyDown"/>
                <TextBox x:Name="editLsoFocusValue" Style="{StaticResource TextBoxS1Style}" Margin="4,0,8,0" KeyDown="EditLsoFocusValue_KeyDown"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnLsoFocusOrigin" Content="0D" Style="{StaticResource ButtonS1Style}" Margin="8,0,4,0" Click="BtnLsoFocusOrigin_Click"/>
                <Button x:Name="btnLsoFocusSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="0,0,16,0" Click="BtnLsoFocusSetAs_Click"/>
                <Button x:Name="btnLsoFocusBwd" Content="1D-" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnLsoFocusBwd_Click"/>
                <Button x:Name="btnLsoFocusFwd" Content="1D+" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnLsoFocusFwd_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Margin="0,0,0,10" Grid.RowSpan="3"/>
        </Grid>
        <Grid Grid.Row="2" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label8" Content="OCT Refer ND" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderOctRefNd" ValueChanged="sliderOctRefNd_ValueChanged" Thumb.DragStarted="sliderOctRefNd_DragStarted" Thumb.DragCompleted="SliderOctRefNd_DragCompleted" Style="{StaticResource SliderStyle}" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
                <TextBox x:Name="editOctRefNdPos" Style="{StaticResource TextBoxS1Style}" Margin="4,0,0,0" KeyDown="EditOctRefNdPos_KeyDown"/>
                <ComboBox x:Name="cmbOctRefNdFilter" Style="{StaticResource ComboBoxStyle}" Width="72" Margin="4,0,12,0"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnOctRefNdSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="8,0,24,0" Click="BtnOctRefNdSetAs_Click"/>
                <Button x:Name="btnOctRefNdOut" Content="Out" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnOctRefNdOut_Click"/>
                <Button x:Name="btnOctRefNdIn" Content="In" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnOctRefNdIn_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.RowSpan="3" Margin="0,0,0,10"/>
        </Grid>
        <Grid Grid.Row="4" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label x:Name="label6" Content="OCT Anterior Lens" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Slider x:Name="sliderAntLens" ValueChanged="sliderAntLens_ValueChanged" Thumb.DragStarted="sliderAntLens_DragStarted" Thumb.DragCompleted="SliderAntLens_DragCompleted" Style="{StaticResource SliderStyle}" HorizontalAlignment="Left" Width="200" Margin="8,0,0,0"/>
                <TextBox x:Name="editAntLensPos" Style="{StaticResource TextBoxS1Style}" Margin="4,0,0,0" KeyDown="EditAntLensPos_KeyDown"/>
                <ComboBox x:Name="cmbAntLensFilter" Style="{StaticResource ComboBoxStyle}" Width="72" Margin="4,0,12,0"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,8,0,24">
                <Button x:Name="btnAntLensSetAs" Content="Set As" Style="{StaticResource ButtonS1Style}" Margin="8,0,24,0" Click="BtnAntLensSetAs_Click"/>
                <Button x:Name="btnAntLensOut" Content="Out" Style="{StaticResource ButtonS1Style}" Margin="0,0,4,0" Click="BtnAntLensOut_Click"/>
                <Button x:Name="btnAntLensIn" Content="In" Style="{StaticResource ButtonS1Style}" Margin="0,0,8,0" Click="BtnAntLensIn_Click"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Grid.RowSpan="3" Margin="0,0,0,10"/>
        </Grid>
    </Grid>
</Window>
